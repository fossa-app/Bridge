{
    "compilerOptions": {
        "target": "ES2020",
        "lib": [
            "ES2020",
            "DOM"
        ],
        "module": "CommonJS",
        "declaration": true,
        "sourceMap": true,
        "outDir": "./dist",
        "rootDir": "./fable_output",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "fable_output/**/*"
    ]
}